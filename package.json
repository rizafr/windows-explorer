{
    "name": "windows-explorer",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "bun run --filter './apps/*' dev",
        "build": "bun run --filter './apps/*' build",
        "test": "bun run --filter './apps/*' test",
        "db:migrate": "bun run --cwd apps/backend db:migrate",
        "db:seed": "bun run --cwd apps/backend db:seed"
    }
}